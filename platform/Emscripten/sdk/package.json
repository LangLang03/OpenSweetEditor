{
  "name": "@sweeteditor/web-sdk-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20 <26",
    "pnpm": ">=10.30.0 <11"
  },
  "scripts": {
    "clean": "node ./scripts/clean-workspace.mjs",
    "build:packages": "pnpm --filter @sweeteditor/core run build && pnpm --filter @sweeteditor/widget run build && pnpm --filter @sweeteditor/providers-sweetline run build && pnpm --filter @sweeteditor/sdk run build",
    "build": "pnpm run build:packages && pnpm --filter @sweeteditor/demo run build",
    "test": "pnpm -r --if-present run test",
    "lint": "pnpm -r --if-present run lint",
    "typecheck": "pnpm -r --if-present run typecheck",
    "docs:api": "node ./scripts/generate-web-api-reference.mjs",
    "build:web-dist": "node ./scripts/build-web-dist.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "eslint": "^9.36.0",
    "fs-extra": "^11.3.2",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  }
}

